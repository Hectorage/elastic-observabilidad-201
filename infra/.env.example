# Versión única del stack Elastic (alinear todos los servicios)
STACK_VERSION=8.17.2

# Recursos JVM del nodo de laboratorio (ajusta si Codespaces tiene poca RAM)
ES_JAVA_OPTS=-Xms768m -Xmx768m

