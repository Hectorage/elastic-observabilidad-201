{
  "name": "Elastic Stack Observabilidad Lab",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "forwardPorts": [9200, 5601],
  "portsAttributes": {
    "5601": {
      "label": "Kibana",
      "onAutoForward": "notify"
    },
    "9200": {
      "label": "Elasticsearch",
      "onAutoForward": "silent"
    }
  },
  "postCreateCommand": "cp --update=none infra/.env.example infra/.env 2>/dev/null || true",
  "customizations": {
    "vscode": {
      "extensions": ["ms-azuretools.vscode-docker"]
    }
  }
}
